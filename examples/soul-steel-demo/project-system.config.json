{
  "$schema": "../../schema/project-config.schema.json",
  "project": "soul-steel-demo",
  "kinds": {
    "decision": {
      "folder": "decisions",
      "status": ["proposed", "accepted", "superseded", "rejected"],
      "initialStatus": "proposed",
      "filename": "serial",
      "serialPad": 4,
      "requiredSections": ["Context"],
      "scaffoldSections": ["Context", "Decision", "Consequences", "Options considered", "Cites", "Re-open if"]
    },
    "report": {
      "folder": "reports",
      "status": ["draft", "complete"],
      "initialStatus": "draft",
      "filename": "date-slug",
      "requiredSections": []
    },
    "pipeline": {
      "folder": "pipeline",
      "status": ["design", "qualify", "build", "ship", "archive", "shelved"],
      "initialStatus": "design",
      "filename": "slug",
      "requiredSections": []
    },
    "roadmap": {
      "folder": "roadmap",
      "status": ["proposed", "active", "superseded", "complete"],
      "initialStatus": "proposed",
      "filename": "slug",
      "requiredSections": ["Context"]
    },
    "session": {
      "folder": "sessions",
      "status": ["planned", "active", "blocked", "completed", "shelved"],
      "initialStatus": "planned",
      "filename": "date-slug",
      "requiredSections": ["Goal", "Success Criteria", "Source References", "Decisions", "Outputs", "Blockers", "Next Action", "Handoff Notes"]
    },
    "character": {
      "folder": "characters",
      "status": ["concept", "draft", "canon", "retired"],
      "initialStatus": "concept",
      "filename": "slug",
      "requiredSections": ["Concept"],
      "scaffoldSections": ["Concept", "Appearance", "Abilities", "Relationships", "Arc"],
      "render": { "dot": "#FF8FB1", "tag": "Characters", "name": "Cast", "sub": "concept → canon" }
    },
    "workflow": {
      "folder": "workflows",
      "status": ["draft", "active", "deprecated"],
      "initialStatus": "draft",
      "filename": "slug",
      "carriesSwimlanes": true,
      "requiredSections": ["Workflow"],
      "scaffoldSections": ["Purpose", "Workflow"],
      "render": { "dot": "#B884FF", "tag": "Workflows", "name": "Swimlanes", "sub": "lanes × steps · replayable process" }
    }
  },
  "sectionHints": {
    "Workflow": "```json\n{\n  \"lanes\": [\n    { \"id\": \"player\", \"label\": \"Player\", \"kind\": \"human\" },\n    { \"id\": \"system\", \"label\": \"System\", \"kind\": \"system\" }\n  ],\n  \"steps\": [\n    { \"id\": \"start\", \"lane\": \"player\", \"label\": \"<trigger>\", \"to\": [\"work\"] },\n    { \"id\": \"work\", \"lane\": \"system\", \"label\": \"<step>\", \"to\": [] }\n  ]\n}\n```",
    "Concept": "<one-line premise — who they are and why they matter>",
    "Appearance": "<visual signature in a sentence>",
    "Abilities": "- **<ability>** — <what it does>",
    "Relationships": "- **<character / faction>** — <bond or conflict>",
    "Arc": "<the change they undergo across the story>"
  },
  "tagRegistry": {
    "priority": { "type": "enum", "values": ["high", "medium", "low"] },
    "agent": { "type": "enum", "values": ["neutral", "codex", "claude", "human"] },
    "scope": { "type": "string", "lintAgainst": ["steel-city", "ip-wide", "tooling"], "unknownAllowed": true },
    "horizon": { "type": "enum", "values": ["milestone", "phase", "cross-domain"] }
  },
  "relTargetKinds": {
    "supersedes": ["decision", "roadmap"],
    "superseded-by": ["decision", "roadmap"],
    "predecessor": ["pipeline", "report"],
    "successor": ["pipeline", "report"],
    "decided-in": ["decision"],
    "milestone": "marker",
    "implements": "external",
    "references": "any"
  },
  "milestones": [],
  "proseStatusEnforcement": { "rollout": "error" }
}
