{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "baseUrl": ".",
    "paths": {
      "@trembus/viz": ["../../../../Repositories/Trembus-Component-Library/packages/viz/dist/index.d.ts"],
      "@trembus/ui": ["../../../../Repositories/Trembus-Component-Library/packages/ui/dist/index.d.ts"]
    },
    "types": ["vite/client", "node"]
  },
  "include": ["src", "vite.config.ts", "scripts"]
}
